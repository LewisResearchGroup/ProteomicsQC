# PROTEOMICSQC PRODUCTION CONFIG

## DOMAIN AND SSL
DOMAIN=proteomicsqc.example.com
ACME_EMAIL=admin@example.com

## HOMEPAGE SETTINGS
HOME_TITLE='Proteomics Pipelines'
HOSTNAME=${DOMAIN}
ALLOWED_HOSTS=${DOMAIN}
CSRF_TRUSTED_ORIGINS=https://${DOMAIN}

## STORAGE (absolute paths recommended for production)
DATALAKE=/data/proteomicsqc/datalake
COMPUTE=/data/proteomicsqc/compute
MEDIA=/data/proteomicsqc/media
STATIC=/data/proteomicsqc/static
DB=/data/proteomicsqc/db

## DATABASE
POSTGRES_PASSWORD=change-this-to-a-secure-password

## EMAIL SETTINGS
EMAIL_HOST=smtp.gmail.com
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_PORT=587
EMAIL_HOST_USER=''
EMAIL_HOST_PASSWORD=''
DEFAULT_FROM_EMAIL=''

## CELERY
CONCURRENCY=8
RESOURCE_RETRY_SECONDS=60
MIN_FREE_MEM_GB_MAXQUANT=8
MAX_LOAD_PER_CPU_MAXQUANT=0.85
MIN_FREE_MEM_GB_RAWTOOLS=2
MAX_LOAD_PER_CPU_RAWTOOLS=0.90

## RESULT STATUS
RESULT_STATUS_INSPECT_TIMEOUT_SECONDS=10.0
RESULT_STATUS_PENDING_STALLED_WARNING_SECONDS=7200
RESULT_STATUS_DONE_MTIME_SKEW_SECONDS=300
RESULT_STATUS_MAXQUANT_STALE_SECONDS=21600
RESULT_STATUS_RAWTOOLS_STALE_SECONDS=3600
RESULT_STATUS_ACTIVITY_FALLBACK_SECONDS=300
RESULT_STATUS_INSPECT_MAX_VISIBLE_RUNS=25
RESULT_STATUS_INSPECT_MAX_ACTIVE_RUNS=12

## USERID (use `id -u`:`id -g` on the host)
UID=1000:1000

## SECURITY KEYS (generate with: openssl rand -hex 32)
SECRET_KEY=generate-a-secure-key-here

## DOCKER IMAGE TAG
IMAGE_TAG=latest
